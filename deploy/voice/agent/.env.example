# Copy to .env on the agent box. Do NOT commit the real .env.

# --- LiveKit (same server/keys as deploy/voice/.env) ---
LIVEKIT_URL=wss://voice.example.com
LIVEKIT_API_KEY=APIxxxxxxxx
LIVEKIT_API_SECRET=secretxxxxxxxxxxxxxxxxxxxxxxxx

# --- LLM: persona router. vLLM serving Qwen2.5-14B-Instruct (OpenAI-compatible) ---
# Start vLLM with tool-calling, e.g.:
#   vllm serve Qwen/Qwen2.5-14B-Instruct --enable-auto-tool-choice --tool-call-parser hermes
LLM_BASE_URL=http://vllm:8000/v1
LLM_MODEL=Qwen/Qwen2.5-14B-Instruct
LLM_API_KEY=none
LLM_TEMPERATURE=0.4

# --- STT: faster-whisper-server (OpenAI /audio/transcriptions) ---
STT_BASE_URL=http://whisper:8000/v1
STT_MODEL=Systran/faster-whisper-large-v3
STT_API_KEY=none

# --- TTS: kokoro-fastapi (OpenAI /audio/speech) ---
TTS_BASE_URL=http://kokoro:8880/v1
TTS_MODEL=kokoro
TTS_VOICE=af_heart
TTS_API_KEY=none
