# Copy to .env and fill in. Do NOT commit the real .env.

# API key/secret pair for LiveKit. Generate with:
#   docker run --rm livekit/livekit-server generate-keys
# Format must be "KEY: SECRET" (single space after colon).
LIVEKIT_KEYS=APIxxxxxxxx: secretxxxxxxxxxxxxxxxxxxxxxxxx

# Public domain for the embedded TURN server (needs a TLS cert in ./certs).
LIVEKIT_TURN_DOMAIN=turn.voice.example.com

# --- Values consumed by happy-server (phase 02) and the agent worker (phase 03) ---
# Keep the same KEY/SECRET as LIVEKIT_KEYS above; these are the split form the
# SDKs expect. happy-server signs join tokens offline with these (it never
# calls LiveKit), so it can run anywhere.
LIVEKIT_URL=wss://voice.example.com        # wss signaling URL the app connects to
LIVEKIT_API_KEY=APIxxxxxxxx
LIVEKIT_API_SECRET=secretxxxxxxxxxxxxxxxxxxxxxxxx
